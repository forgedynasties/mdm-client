android_app {
    name: "mdm-client",
    srcs: ["src/**/*.java"],
    certificate: "platform",
    privileged: true,
    platform_apis: true,
    dex_preopt: {
        enabled: false,
    },
    required: ["mdm-client-sysconfig"],
}

prebuilt_etc {
    name: "mdm-client-sysconfig",
    src: "sysconfig/com.aioapp.mdm.xml",
    sub_dir: "sysconfig",
}
